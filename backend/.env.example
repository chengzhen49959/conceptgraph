# Cognito — from your User Pool's "App integration" page. The backend uses these
# to verify the JWT the frontend forwards (signature + claims). No AWS secret keys
# are needed for verification.
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_APP_CLIENT_ID=your-app-client-id

# Aurora PostgreSQL — async SQLAlchemy URL (note the +asyncpg driver).
DATABASE_URL=postgresql+asyncpg://user:password@your-cluster-host:5432/postgres

# Browser origin allowed by CORS (the Next.js dev server).
FRONTEND_ORIGIN=http://localhost:3000

# Extra CORS origins (comma-separated) — the Chrome clipper extension. Its id is
# pinned by the manifest "key", so the origin is stable. See extension/README.md.
# EXTENSION_ORIGINS=chrome-extension://bknaciplmhinobiglpkofbimbfamflpg

# --- Ingestion pipeline ------------------------------------------------------
# OpenAI — embeddings + concept extraction + merge confirmation + cluster labels.
OPENAI_API_KEY=sk-...

# Redis — arq job queue and the per-workspace merge lock. Local: redis://localhost:6379.
# Render Key Value provides a redis:// URL.
REDIS_URL=redis://localhost:6379

# S3 — raw uploaded documents. The backend issues presigned PUT URLs; the worker
# fetches the object to parse. The bucket must allow PUT (CORS) from FRONTEND_ORIGIN.
S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1
# Optional — leave blank to use the default boto3 credential chain (env, shared
# config, or instance role).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Optional model / tuning overrides (sensible defaults in app/config.py) ---
# EMBED_MODEL=text-embedding-3-small
# EXTRACT_MODEL=gpt-5.4-nano
# CONFIRM_MODEL=gpt-5.4-nano
# LABEL_MODEL=gpt-5.4-mini
# EMBED_DIM=1536
# MERGE_DISTANCE=0.20

# --- MCP server (OAuth 2.1 resource server; AI-client external memory) --------
# The MCP server is mounted at /mcp and lets AI clients (Claude/ChatGPT/Cursor)
# use the knowledge base as external memory. OAuth uses Cognito as the
# Authorization Server; provision the bits once with `uv run python
# _provision_cognito.py` (creates the Hosted UI domain, resource server, and a
# static client), then set:
#   COGNITO_DOMAIN — Hosted UI domain prefix (or full host), e.g. conceptgraph-auth
#   MCP_RESOURCE_IDENTIFIER — resource-server id; scopes are <id>/read, <id>/write
#   MCP_PUBLIC_URL — this backend's public origin (OAuth issuer + /mcp resource);
#                    http://127.0.0.1:8000 locally, the Render URL in production
COGNITO_DOMAIN=
MCP_RESOURCE_IDENTIFIER=concept-graph
MCP_PUBLIC_URL=http://127.0.0.1:8000
# MCP_ENABLED=true
# Redirect-URI prefixes the /register DCR shim accepts (comma-separated).
# MCP_ALLOWED_REDIRECT_SCHEMES=https://,http://localhost,http://127.0.0.1
