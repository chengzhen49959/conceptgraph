# Supabase — copy from your project's Settings → API page.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Secret key (sb_secret_...) — or the legacy service_role key. Server-side ONLY:
# full access, bypasses Row Level Security. Never expose in the frontend or
# commit the real value.
SUPABASE_SECRET_KEY=your-secret-or-service-role-key

# Browser origin allowed by CORS (the Next.js dev server).
FRONTEND_ORIGIN=http://localhost:3000
