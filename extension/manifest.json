{
  "manifest_version": 3,
  "name": "Graph Clipper",
  "version": "0.1.0",
  "description": "Clip a web page's clean main text into your concept graph.",
  "key": "",
  "action": {
    "default_title": "Clip to graph"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["fab.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "scripting", "cookies", "storage", "contextMenus", "sidePanel"],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Open the clipper panel"
    }
  }
}
