# Build-time config for the clipper (consumed by build.mjs via esbuild `define`).
# Unset → localhost dev defaults below. Export these before `npm run build:prod`
# to target a deployed app/backend.

# Where the web app runs (its Cognito session cookies are read here; also the
# "View in graph" / sign-in destination). Must match a manifest host_permission.
APP_ORIGIN=http://localhost:3000

# FastAPI backend origin the clip request is POSTed to.
API_BASE=http://127.0.0.1:8000

# Cognito App Client + User Pool (same values as the web app's
# NEXT_PUBLIC_COGNITO_CLIENT_ID / NEXT_PUBLIC_COGNITO_USER_POOL_ID). The region
# is inferred from the pool id ("us-east-1_xxx" → "us-east-1").
COGNITO_CLIENT_ID=
COGNITO_USER_POOL_ID=
