# Cognito — from your User Pool's "App integration" page. Region is inferred
# from the User Pool ID, so it isn't needed here. These are public (browser-safe).
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=your-app-client-id

# FastAPI backend origin. Defaults to http://127.0.0.1:8000 if unset.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
