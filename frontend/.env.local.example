# Supabase — copy from your project's Settings → API page.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Publishable key (sb_publishable_...) — or the legacy anon key. Public,
# browser-safe; it respects Row Level Security.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# FastAPI backend origin. Defaults to http://127.0.0.1:8000 if unset.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
